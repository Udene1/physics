# AI Learning Companion Configuration
# -----------------------------------------------------------------

# 1. Get your API Key from https://aistudio.google.com/
# LLM Configurations (Use one or both)
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here_for_ultrafast_free_tier
MISTRAL_API_KEY=your_mistral_key_here

# Backend Selection: auto, gemini, groq, mistral, ollama
LLM_BACKEND=auto
# 2. Set backend to 'gemini' to force cloud mode (optional)
# If not set, it will auto-detect between Gemini and local Ollama.
LLM_BACKEND=auto
