# AI Learning Companion Configuration
# -----------------------------------------------------------------

# 1. Get your API Key from https://aistudio.google.com/
GEMINI_API_KEY=your_genai_api_key_here

# 2. Set backend to 'gemini' to force cloud mode (optional)
# If not set, it will auto-detect between Gemini and local Ollama.
LLM_BACKEND=auto
